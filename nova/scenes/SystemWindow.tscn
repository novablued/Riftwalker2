[gd_scene load_steps=3 format=3 uid="uid://systemwindow"]

[sub_resource type="GDScript" id="GDScript_system"]
script/source = "extends CanvasLayer
class_name SystemWindow

@onready var hp_bar: ProgressBar = $HBoxContainer/HPBar
@onready var link_timer: Label = $HBoxContainer/LinkTimer  
@onready var revenant_count: Label = $HBoxContainer/RevenantCount

var nova_hp: float = 100.0
var max_hp: float = 100.0
var link_time: float = 0.0
var revenants: int = 0

func _ready():
hp_bar.max_value = max_hp
hp_bar.value = nova_hp
update_ui()

func _process(delta):
if link_time > 0:
k_time -= delta
k_timer.text = \"LINK: %.1fs\" % link_time
else:
k_timer.text = \"LINK: READY\"
update_ui()

func update_ui():
hp_bar.value = nova_hp
revenant_count.text = \"REVENANTS: %d/3\" % revenants

func take_damage(amount: float):
nova_hp -= amount
if nova_hp < 0:
ova_hp = 0
update_ui()

func activate_link(burst_time: float = 15.0):
link_time = burst_time

func add_revenant():
if revenants < 3:
ants += 1
ode name="SystemWindow" type="CanvasLayer"]
